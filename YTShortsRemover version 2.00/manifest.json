{
  "manifest_version": 3,
  "name": "YT Shorts Remover",
  "version": "1.0",

  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["hide-shorts.css"],
      "run_at": "document_start"
    }
  ]
}